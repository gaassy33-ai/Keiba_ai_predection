# 環境変数（絶対にコミットしない）
.env
*.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/

# データファイル（大容量）
data/raw/
data/processed/
data/models/*.pkl
data/models/*.bin
# 学習済みモデル・統計はリポジトリに含める（JRA + NAR）
!data/models/lgbm_model.pkl
!data/models/lgbm_model_bad_season.pkl
!data/models/feature_stats.pkl
!data/models/nar_lgbm_model.pkl
!data/models/nar_feature_stats.pkl
!data/models/feature_importance.json
!data/models/nar_feature_importance.json
# Two-Brain System（LTR + Gatekeeper + PairCalibrator）
!data/models/lgbm_ltr_model.pkl
!data/models/gatekeeper_model.pkl
!data/models/pair_calibrator.pkl
!data/models/ltr_feature_importance.json
!data/models/gatekeeper_feature_importance.json
# 週次収集データもリポジトリに含める（collect_weekly.yml が更新）
!data/raw/test_results.csv
!data/raw/test_meta.csv
!data/raw/nar_results.csv
!data/raw/nar_meta.csv

# ログ（テキストログのみ除外。data/logs/ はリポジトリに含める）
logs/
# 2026-06-27: 朝バッチ/夕方バッチ/週末まとめが別々のGitHub Actions runner
# （≠同一checkout）で実行されるため、artifactアーカイブのみでは
# ジョブ間でデータを引き渡せない（夕方バッチが当日の予想を見つけられない
# 問題が発生）。data/logs/ をgit管理化し、各ジョブが commit & push する
# ことでジョブ間・週次でのデータ継続性を確保する。
!data/logs/

# Jupyter
.ipynb_checkpoints/
notebooks/*.ipynb

# IDE
.vscode/
.idea/
*.swp

# macOS
.DS_Store

# Chrome / Selenium
chromedriver
chromedriver.exe
